media screen and (max-width: 768px) {
    body {
        font-size: 16px; /* Example: Increase font size for smaller screens */
    }

    .container {
        width: 100%; /* Make the container full-width for smaller screens */
    }

    /* Add more styles for smaller screens as needed */

    /* Example: Style changes for smaller screens */
    .img1, .img2 {
        width: 100%; /* Make images full-width for smaller screens */
        height: auto; /* Maintain image aspect ratio */
    }

    .parent {
        display: block; /* Return to a single column layout for smaller screens */
    }

    .child {
        width: 100%; /* Make each child element full-width for smaller screens */
    }
}
